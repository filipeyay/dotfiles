{
  "layer": "bottom",
  "position": "top",
  "height": 42,
  "margin-top": 8,
  "margin-right": 8,
  "margin-left": 8,
  "spacing": 0,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/org-clock",
    "idle_inhibitor",
    "pulseaudio",
    "network",
    "battery"
  ],
  "sway/window": {
    "format": "",
    "max-length": 40
  },
  "clock": {
    "format": "{:%H:%M %p - %a, %d %b %Y}",
    "tooltip": false
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 5
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% (charging)",
    "format-plugged": "{capacity}% (plugged)",
    "format-icons": [
      " ",
      " ",
      " ",
      " ",
      " "
    ]
  },
  "network": {
    "format-wifi": "wi-fi ({signalStrength}%)  ",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr}  ",
    "format-disconnected": "Disconnected ⚠"
  },
  "custom/org-clock": {
    "exec": "$HOME/.config/waybar/org-clock2.sh",
    "interval": 60,
    "return-type": "json"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": " ",
      "deactivated": " "
    }
  },
  "pulseaudio": {
    //"scroll-step": 1,
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}",
    "format-muted": " ",
    "format-icons": {
      "headphones": "",
      "handsfree": "",
      "headset": "",
      "phone": "",
      "portable": "",
      "car": "",
      "default": [
        " ",
        " "
      ]
    },
    "on-click": "pavucontrol"
  }
}
