{
  "layer": "bottom",
  "position": "top",
  "height": 42,
  "margin-top": 8,
  "margin-right": 8,
  "margin-left": 8,
  "spacing": 0,
  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "sway/window"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "custom/org-clock",
    "tray",
    "sway/language",
    "idle_inhibitor",
    "pulseaudio",
    "network",
    "battery",
    "custom/lock",
    "custom/logout",
    "custom/reboot",
    "custom/shutdown"
  ],
  "sway/window": {
    "format": "",
    "max-length": 40
  },
  "tray": {
    "icon-size": 21,
    "spacing": 10,
    "show-passive-items": true
  },
  "sway/language": {
    "format": "{short} {flag}",
    "tooltip": true,
    "on-click": "swaymsg input type:keyboard xkb_switch_layout next"
  },
  "clock": {
    "format": "{:%H:%M %p - %a, %d %b %Y}",
    "tooltip": false
  },
  "battery": {
    "bat": "BAT0",
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 5
    },
    "format": "{capacity}% {icon}",
    "format-charging": "тЪб{capacity}% {icon}",
    "format-plugged": "ЁЯФМ{capacity}% {icon}",
    "format-icons": [
      "яЙД ",
      "яЙГ ",
      "яЙВ ",
      "яЙБ ",
      "яЙА "
    ]
  },
  "network": {
    "format-wifi": "{essid} ({signalStrength}%) яЗл ",
    "format-ethernet": "{ifname}: {ipaddr}/{cidr} яГБ ",
    "format-disconnected": "Disconnected тЪа",
    "tooltip-format-wifi": "{essid} - {ipaddr}"
  },
  "bluetooth": {
    "format": "{icon}",
    "format-icons": {
      "enabled": "яКФ",
      "disabled": "яКУ"
    }
  },
  "custom/org-clock": {
    "exec": "$HOME/.config/waybar/org-clock2.sh",
    "interval": 60,
    "return-type": "json"
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "яБо ",
      "deactivated": "яБ░ "
    }
  },
  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-bluetooth": "{volume}% {icon}яКФ",
    "format-muted": "яАж ",
    "format-icons": {
      "headphones": "яАе",
      "handsfree": "яЦР",
      "headset": "яЦР",
      "phone": "яВХ",
      "portable": "яВХ",
      "car": "яЖ╣",
      "default": [
        "яАз ",
        "яАи "
      ]
    },
    "on-click": "pavucontrol"
  },
  "custom/lock": {
    "format": "яАг ",
    "tooltip": "Lock Screen",
    "on-click": "swaylock -f --image '/home/filipe/Imagens/Wallpaper/world-map-black-and-3840x2160-16671.png'",
    "interval": "once"
  },
  "custom/logout": {
    "format": "яВЛ ",
    "tooltip": "Logout",
    "on-click": "swaymsg exit",
    "interval": "once"
  },
  "custom/reboot": {
    "format": "яАЮ ",
    "tooltip": "Reboot",
    "on-click": "reboot",
    "interval": "once"
  },
  "custom/shutdown": {
    "format": "яАС ",
    "tooltip": "Shutdown",
    "on-click": "poweroff",
    "interval": "once"
  }
}
